# Password-gate (trademark safety) — required
# Memorable password you share with the business owner.
SITE_PASSWORD=

# HMAC secret used to sign the auth cookie. 32 random bytes hex.
# Generate with:  openssl rand -hex 32
# Rotating this value invalidates all existing sessions.
SITE_AUTH_SECRET=

# Production base URL for canonical URLs + sitemap. No trailing slash.
# Example: https://consultec.swiss  (or the Vercel preview URL during pitch)
NEXT_PUBLIC_SITE_URL=https://consultec-rebuild.vercel.app
